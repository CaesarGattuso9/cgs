# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-secure-secret
AUTH_SECRET=replace-with-a-secure-secret
AUTH_COOKIE_SECURE=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# Database
DATABASE_URL=postgresql://lifelog:lifelog@localhost:5432/lifelog?schema=public

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lifelog-media
MINIO_USE_SSL=false

# Grok / xAI
GROK_API_KEY=your-grok-api-key
GROK_BASE_URL=https://api.x.ai/v1
GROK_CHAT_MODEL=grok-3-latest
GROK_IMAGE_MODEL=grok-2-image-latest
GROK_VIDEO_MODEL=grok-video-latest
